# Example variable values. Copy to terraform.tfvars and adjust.
# NEVER put real secrets or account IDs here. DB password is generated by
# Terraform (random_password) and stored in Secrets Manager — not set here.

aws_region   = "eu-west-2"
project_name = "ecs-fargate-vpc-platform"
environment  = "dev"

vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]

container_port = 8000

db_name           = "appdb"
db_username       = "appuser"
db_engine_version = "16.4"
db_instance_class = "db.t3.micro"
db_multi_az       = false

log_retention_days = 14
